# ─── Vampire High (guest-only deployment) ───────────────────────────
# Railway injects PORT automatically — do NOT hardcode it.

# Required: MySQL connection string.
# On Railway, add a MySQL plugin and reference its variable, e.g.:
#   DATABASE_URL=${{MySQL.MYSQL_URL}}
DATABASE_URL=mysql://user:password@host:3306/railway

# Set by platform; included for completeness.
NODE_ENV=production

# ─── No longer required (guest-only build) ──────────────────────────
# The following were needed only for Manus OAuth / storage and are now unused:
#   JWT_SECRET, OAUTH_SERVER_URL, OWNER_OPEN_ID, VITE_APP_ID,
#   VITE_OAUTH_PORTAL_URL, BUILT_IN_FORGE_API_URL, BUILT_IN_FORGE_API_KEY
# You can leave them unset.
